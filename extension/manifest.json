{
  "name": "QA Copilot",
  "version": "2.1",
  "description": "Send Jira tickets to QA Copilot for test planning and bug reporting.",
  "manifest_version": 3,
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://*.atlassian.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
